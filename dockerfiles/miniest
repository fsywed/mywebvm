FROM --platform=i386 debian:bookworm-slim
ARG DEBIAN_FRONTEND=noninteractive

# 只装核心工具：Git + 编译器 + Python
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    build-essential \
    gcc \
    g++ \
    python3 \
    python3-pip \
    curl \
    ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && rm -rf /tmp/*

# 创建用户（保持WebVM习惯）
RUN useradd -m user && echo "user:password" | chpasswd
RUN echo 'root:password' | chpasswd

# 设置工作目录和环境变量（只写一次）
WORKDIR /home/user/
ENV HOME="/home/user" \
    TERM="xterm" \
    USER="user" \
    SHELL="/bin/bash"

# 启动命令（只写一次）
CMD ["/bin/bash"]
