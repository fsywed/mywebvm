FROM --platform=i386 i386/debian:bookworm
ARG DEBIAN_FRONTEND=noninteractive

# 核心工具：Git + 编译器 + Python
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    build-essential \
    gcc \
    g++ \
    python3 \
    python3-pip \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# 游戏依赖（图形+非图形）
RUN apt-get update && apt-get install -y --no-install-recommends \
    # 图形游戏依赖（SDL系列）
    libsdl2-dev \
    libsdl2-image-dev \
    libsdl2-mixer-dev \
    libsdl2-ttf-dev \
    libgl1-mesa-dev \
    libglu1-mesa-dev \
    # 非图形游戏依赖（终端游戏）
    libncurses5-dev \
    libncursesw5-dev \
    # GNOME游戏支持库
    libgnome-games-support-1-3 \
    # 游戏内容开发工具（Blender/GIMP等推荐）
    games-content-dev \
    && rm -rf /var/lib/apt/lists/*

# 创建用户（保持WebVM习惯）
RUN useradd -m user && echo "user:password" | chpasswd
RUN echo 'root:password' | chpasswd

WORKDIR /home/user/
ENV HOME="/home/user" TERM="xterm" USER="user" SHELL="/bin/bash"
CMD [ "/bin/bash" ]
